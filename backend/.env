# App configuration prefix: APP_
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# Security
APP_SECRET_KEY=change-this-to-a-very-secure-secret-key-32-chars-at-least-!
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database URL (pointing to postgres service in Docker Compose network)
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_student_os

# Redis URL (pointing to redis service in Docker Compose network)
APP_REDIS_URL=redis://redis:6379/0

# Google OAuth Credentials (configured in Google Cloud Console Credentials)
APP_GOOGLE_CLIENT_ID=google-client-id-placeholder

# Resend API Key for Email Verification
# If left empty, email verifications are printed to the console in local development
APP_RESEND_API_KEY=
APP_FROM_EMAIL=onboarding@resend.dev

# CORS Settings (comma-separated origins)
APP_ALLOWED_ORIGINS=http://localhost:3000
